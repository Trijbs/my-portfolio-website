{
  "name": "portfolio-vercel",
  "version": "1.0.0",
  "type": "module",
  "description": "Portfolio website with Vercel serverless functions for contact form and analytics",
  "scripts": {
    "dev": "npx vercel dev",
    "start": "npx vercel dev",
    "deploy": "npx vercel --prod",
    "test:email": "node test-email-config.js",
    "build:media": "node scripts/build-media.mjs",
    "check:media": "node scripts/build-media.mjs --check"
  },
  "keywords": [
    "portfolio",
    "vercel",
    "serverless",
    "contact-form",
    "analytics",
    "nodejs"
  ],
  "author": "Trijbs",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.56.1",
    "@vercel/analytics": "^1.1.1",
    "dotenv": "^16.3.1",
    "nodemailer": "^7.0.13",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
